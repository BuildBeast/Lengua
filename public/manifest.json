{
  "manifest_version": 3,
  "name": "Lengua",
  "version": "0.1.0",
  "description": "Spanish learning companion (YouTube + Canal Sur) in a Chrome side panel.",
  "permissions": ["sidePanel", "tabs", "tabCapture", "offscreen", "activeTab"],
  "host_permissions": [
    "*://*.youtube.com/*",
    "*://*.canalsur.es/*",
    "*://*.canalsurmas.es/*"
  ],
  "background": {
    "service_worker": "serviceWorker.js",
    "type": "module"
  },
  "action": {
    "default_title": "Open Lengua"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["captionInterceptor.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["youtubeDetector.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://*.canalsur.es/*", "*://*.canalsurmas.es/*"],
      "js": ["canalSurDetector.js"],
      "run_at": "document_idle"
    }
  ]
}
